---
layout: base.njk
title: Registration
description: Registration for ACM CAIS 2026 (May 26–29, San Jose, CA) is opening soon.
permalink: /pages/registration/
---

<header class="hero">
  <div class="container">
    <h1 class="display-5 fw-bold mb-3">Registration</h1>
    <p class="lead mb-0">ACM Conference on AI and Agentic Systems (ACM CAIS 2026)</p>
  </div>
</header>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <div class="alert alert-info text-center mb-4" role="alert">
          <i class="bi bi-info-circle me-2"></i>
          <strong>Registration is opening soon.</strong> Details on registration categories and pricing will be available when registration opens.
        </div>

        <div class="card p-4 mb-4" style="border: 2px solid var(--terracotta-deep); border-radius: 4px;">
          <div class="text-center">
            <h2 class="h4 fw-bold mb-3">CAIS 2026</h2>
            <p class="lead mb-1"><strong>{{ site.dates.display }}</strong></p>
            <p class="mb-1">{{ site.location }}</p>
            <p class="text-muted mb-0">{{ site.venue.name }}</p>
          </div>
        </div>

        <div class="mb-4" style="background: rgba(149, 108, 88, 0.05); padding: 1.5rem; border-radius: 4px; border: 1px solid var(--platinum);">
          <h2 class="h5 fw-bold mb-2">Get Notified When Registration Opens</h2>
          <p class="mb-3">Subscribe to the CAIS mailing list to be notified as soon as registration is available.</p>
          <a href="{{ site.forms.subscribe }}" class="btn btn-primary" style="background:var(--cais-accent); border:none; color:#fff;" target="_blank" rel="noopener">
            <i class="bi bi-envelope me-2"></i>Subscribe for Updates
          </a>
        </div>

        <div class="mb-4" style="background: rgba(149, 108, 88, 0.05); padding: 1.5rem; border-radius: 4px; border: 1px solid var(--platinum);">
          <h2 class="h5 fw-bold mb-2"><i class="bi bi-building me-2"></i>Venue &amp; Accommodation</h2>
          <p class="mb-2">The conference will be held at the <strong>{{ site.venue.name }}</strong>, {{ site.venue.streetAddress }}, {{ site.venue.city }}, {{ site.venue.state }} {{ site.venue.zip }}.</p>
          <p class="mb-3">A discounted group rate of <strong>{{ site.venue.groupRate }}</strong> is available for attendees.</p>
          <a href="{{ site.venue.bookingUrl }}" class="btn btn-outline-primary" target="_blank" rel="noopener">
            <i class="bi bi-calendar-check me-2"></i>Book Hotel Room
          </a>
        </div>

        <div style="background: rgba(149, 108, 88, 0.05); padding: 1.5rem; border-radius: 4px; border: 1px solid var(--platinum);">
          <h2 class="h5 fw-bold mb-2">Questions?</h2>
          <p class="mb-0">For registration inquiries, contact us at <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>.</p>
        </div>

      </div>
    </div>
  </div>
</section>
