---
layout: base.njk
title: Registration
description: Register now for ACM CAIS 2026 (May 26–29, San Jose, CA). Early-bird pricing available through May 5, 2026.
permalink: /pages/registration/
---

<header class="hero">
  <div class="container">
    <h1 class="display-5 fw-bold mb-3">Registration</h1>
    <p class="lead mb-0">ACM Conference on AI and Agentic Systems (ACM CAIS 2026)</p>
  </div>
</header>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-10">

        <!-- Register Now CTA -->
        <div class="mb-5 d-flex flex-column flex-md-row align-items-stretch gap-0" style="border: 2px solid var(--terracotta-deep); border-radius: 4px; overflow: hidden;">
          <div class="flex-grow-1 p-4 d-flex flex-column justify-content-center">
            <h2 class="h4 fw-bold mb-1">Registration Is Open</h2>
            <p class="mb-2" style="color: var(--davys-gray);">{{ site.dates.display }} · {{ site.location }} · {{ site.venue.name }}</p>
            <p class="mb-0 small" style="color: var(--olive-moss); font-weight: 600;"><i class="bi bi-clock me-1"></i>Early-bird pricing through {{ site.registration.earlyBirdDeadline.display }}</p>
          </div>
          <div class="d-flex align-items-center justify-content-center p-4" style="background: var(--terracotta-deep);">
            <a href="{{ site.registration.url }}" class="btn btn-lg px-4 fw-bold text-nowrap" style="background:#fff; color:var(--terracotta-deep); border:none;" target="_blank" rel="noopener">
              Register Now <i class="bi bi-arrow-right ms-2"></i>
            </a>
          </div>
        </div>

        <!-- Pricing Tables -->
        <h2 class="h4 fw-bold mb-4">Conference Registration</h2>
        <p class="mb-3">Full conference registration includes access to all main conference sessions (May 27-29) as well as the workshop day (May 26), coffee breaks, lunches, and the reception.</p>

        <div class="table-responsive mb-5">
          <table class="table table-sm align-middle">
            <thead>
              <tr class="table-light">
                <th>Category</th>
                <th class="text-end">Early Bird<br><small class="fw-normal text-muted">through {{ site.registration.earlyBirdDeadline.display }}</small></th>
                <th class="text-end">Standard</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>ACM Student Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.conference.earlyACMStudent }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.conference.lateACMStudent }}</td>
              </tr>
              <tr>
                <td>Student Non-Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.conference.earlyStudentNonMember }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.conference.lateStudentNonMember }}</td>
              </tr>
              <tr>
                <td>ACM Member</td>
                <td class="text-end"><strong>$1,050</strong></td>
                <td class="text-end">$1,500</td>
              </tr>
              <tr>
                <td>Non-Member</td>
                <td class="text-end"><strong>$1,300</strong></td>
                <td class="text-end">$1,750</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2 class="h4 fw-bold mb-4">Workshop-Only Registration</h2>
        <p class="mb-3">Workshop-only registration covers the workshop day (May 26) only, and does not include access to the main conference sessions.</p>

        <div class="table-responsive mb-5">
          <table class="table table-sm align-middle">
            <thead>
              <tr class="table-light">
                <th>Category</th>
                <th class="text-end">Early Bird<br><small class="fw-normal text-muted">through {{ site.registration.earlyBirdDeadline.display }}</small></th>
                <th class="text-end">Standard</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>ACM Student Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.workshopOnly.earlyACMStudent }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.workshopOnly.lateACMStudent }}</td>
              </tr>
              <tr>
                <td>Student Non-Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.workshopOnly.earlyStudentNonMember }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.workshopOnly.lateStudentNonMember }}</td>
              </tr>
              <tr>
                <td>ACM Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.workshopOnly.earlyACMMember }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.workshopOnly.lateACMMember }}</td>
              </tr>
              <tr>
                <td>Non-Member</td>
                <td class="text-end"><strong>${{ site.registration.pricing.workshopOnly.earlyNonMember }}</strong></td>
                <td class="text-end">${{ site.registration.pricing.workshopOnly.lateNonMember }}</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- ACM Membership note -->
        <div class="alert alert-info mb-5" role="alert">
          <i class="bi bi-info-circle me-2"></i>
          <strong>Save with ACM membership.</strong> Not yet a member? <a href="https://www.acm.org/membership" target="_blank" rel="noopener" class="alert-link">Join ACM</a> before registering to receive member pricing.
        </div>

        <!-- Second Register CTA -->
        <div class="text-center mb-5">
          <a href="{{ site.registration.url }}" class="btn btn-primary btn-lg px-5" style="background:var(--cais-accent); border:none; color:#fff;" target="_blank" rel="noopener">
            <i class="bi bi-ticket-perforated me-2"></i>Register Now
          </a>
        </div>

        <!-- Venue & Accommodation -->
        <div class="mb-4" style="background: rgba(149, 108, 88, 0.05); padding: 1.5rem; border-radius: 4px; border: 1px solid var(--platinum);">
          <h2 class="h5 fw-bold mb-2"><i class="bi bi-building me-2"></i>Venue &amp; Accommodation</h2>
          <p class="mb-2">The conference will be held at the <strong>{{ site.venue.name }}</strong>, {{ site.venue.streetAddress }}, {{ site.venue.city }}, {{ site.venue.state }} {{ site.venue.zip }}.</p>
          <p class="mb-3">A discounted group rate of <strong>{{ site.venue.groupRate }}</strong> is available for attendees.</p>
          <a href="{{ site.venue.bookingUrl }}" class="btn btn-outline-primary" target="_blank" rel="noopener">
            <i class="bi bi-calendar-check me-2"></i>Book Hotel Room
          </a>
        </div>

        <!-- Questions -->
        <div style="background: rgba(149, 108, 88, 0.05); padding: 1.5rem; border-radius: 4px; border: 1px solid var(--platinum);">
          <h2 class="h5 fw-bold mb-2">Questions?</h2>
          <p class="mb-0">For registration inquiries, contact us at <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>.</p>
        </div>

      </div>
    </div>
  </div>
</section>
