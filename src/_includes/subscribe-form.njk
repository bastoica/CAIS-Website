{#
  Buttondown subscribe form macro.

  Parameters:
    layout   – "inline" (horizontal) or "stacked" (vertical)  [default: "inline"]
    inputId  – unique HTML id for the email input               [default: "bd-email"]
    btnClass – extra classes on the submit button                [default: ""]
    btnStyle – inline style on the submit button                 [default: uses cais-accent]
#}
{% macro subscribe(layout="inline", inputId="bd-email", btnClass="", btnStyle="background:var(--cais-accent); border:none; color:#fff;") %}
<form class="subscribe-form subscribe-form--{{ layout }}"
      action="https://buttondown.com/api/emails/embed-subscribe/caisconf"
      method="post" referrerpolicy="unsafe-url">
  {% if layout == "inline" %}
  <div class="input-group">
    <input type="email" name="email" id="{{ inputId }}" class="form-control"
           placeholder="Your email address" required aria-label="Email address">
    <button type="submit" class="btn {{ btnClass }}" style="{{ btnStyle }}">Subscribe</button>
  </div>
  <a href="#" class="subscribe-extra-toggle text-muted d-inline-block mt-1" style="font-size:.78rem; text-decoration:none;">
    <i class="bi bi-plus-circle me-1"></i>Add name &amp; affiliation
  </a>
  <div class="subscribe-extra-fields d-none d-flex gap-2 mt-1">
    <input type="text" name="name" class="form-control form-control-sm"
           placeholder="Name (optional)" aria-label="Name (optional)">
    <input type="text" name="affiliation" class="form-control form-control-sm"
           placeholder="Affiliation (optional)" aria-label="Affiliation (optional)">
  </div>
  {% else %}
  <input type="email" name="email" id="{{ inputId }}" class="form-control mb-2"
         placeholder="Your email address" required aria-label="Email address">
  <input type="text" name="name" class="form-control form-control-sm mb-2"
         placeholder="Name (optional)" aria-label="Name (optional)">
  <input type="text" name="affiliation" class="form-control form-control-sm mb-2"
         placeholder="Affiliation (optional)" aria-label="Affiliation (optional)">
  <button type="submit" class="btn w-100 {{ btnClass }}" style="{{ btnStyle }}">
    <i class="bi bi-envelope me-2"></i>Subscribe for Updates
  </button>
  {% endif %}
</form>
{% endmacro %}
