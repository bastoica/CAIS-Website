{# Committee member card component #}
{# Usage: {% include "committee-card.njk" %} with member, isSteering variables #}
<div class="col-md-6 col-lg-4">
    <div class="committee-card {{ 'steering-card' if isSteering else '' }} h-100 p-3 rounded">
        <div class="committee-header">
            <img src="/assets/images/{{ member.photo }}" alt="{{ member.name }}" class="committee-photo" loading="lazy" />
            <div>
                {% if isSteering %}
                <span class="role-badge">Steering Committee</span>
                {% endif %}
                <h3 class="committee-name">{{ member.name }}</h3>
                <p class="committee-affiliation">{{ member.affiliation }}</p>
                {% if member.role %}
                <p class="committee-role mb-0">{{ member.role }}</p>
                {% endif %}
            </div>
        </div>
        <p class="committee-bio">{{ member.bio }}</p>
    </div>
</div>
