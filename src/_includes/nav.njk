<!-- ===== NAV ===== -->
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top" aria-label="Primary navigation">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/" aria-label="{{ site.name }} Home">
            <img src="/assets/images/CAIS Logo Long.svg" alt="{{ site.name }}" class="brand-logo" loading="eager" decoding="async" style="height:48px; width:auto; display:block;" />
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="navMain" class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-lg-center">
                {% for item in navigation.main %}
                {% if item.children %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="navDropdown{{ loop.index }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        {{ item.label }}
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="navDropdown{{ loop.index }}">
                        {% for child in item.children %}
                        <li>
                            {% if child.disabled %}
                            <span class="dropdown-item disabled" aria-disabled="true">{{ child.label }}</span>
                            {% elif page.url == child.href or (child.href != "/" and page.url.startsWith(child.href)) %}
                            <a class="dropdown-item active" aria-current="page" href="{{ child.href }}">{{ child.label }}</a>
                            {% else %}
                            <a class="dropdown-item" href="{{ child.href }}">{{ child.label }}</a>
                            {% endif %}
                        </li>
                        {% endfor %}
                    </ul>
                </li>
                {% else %}
                <li class="nav-item">
                    {% if item.disabled %}
                    <a class="nav-link disabled" href="{{ item.href }}" aria-disabled="true">{{ item.label }}</a>
                    {% elif page.url == item.href or (item.href != "/" and page.url.startsWith(item.href)) %}
                    <a class="nav-link active" aria-current="page" href="{{ item.href }}">{{ item.label }}</a>
                    {% else %}
                    <a class="nav-link" href="{{ item.href }}">{{ item.label }}</a>
                    {% endif %}
                </li>
                {% endif %}
                {% endfor %}
                <li class="nav-item dropdown">
                    <a class="nav-link btn btn-sm ms-lg-2 dropdown-toggle" href="#" role="button"
                       data-bs-toggle="dropdown" aria-expanded="false">Get Updates</a>
                    <div class="dropdown-menu dropdown-menu-end p-3" style="min-width:300px;">
                        <div class="mb-2 small fw-bold">Subscribe for updates</div>
                        <form class="subscribe-form"
                              action="https://buttondown.com/api/emails/embed-subscribe/caisconf"
                              method="post" referrerpolicy="unsafe-url">
                            <div class="input-group input-group-sm">
                                <input type="email" name="email" id="bd-email-nav" class="form-control"
                                       placeholder="Your email" required aria-label="Email address">
                                <button type="submit" class="btn"
                                        style="background:var(--cais-accent); color:#fff;">Subscribe</button>
                            </div>
                            <input type="text" name="name" class="form-control form-control-sm mt-2"
                                   placeholder="Name (optional)" aria-label="Name (optional)">
                            <input type="text" name="affiliation" class="form-control form-control-sm mt-2"
                                   placeholder="Affiliation (optional)" aria-label="Affiliation (optional)">
                        </form>
                    </div>
                </li>
                <li class="nav-item ms-lg-1">
                    <a class="nav-link btn btn-sm px-3 fw-bold" href="https://acm-cais26.hotcrp.com/" target="_blank" rel="noopener" style="background:var(--cais-accent) !important; color:#fff !important;">
                        <i class="bi bi-box-arrow-up-right me-1"></i>Submit Paper
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>